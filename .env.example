# =============================================================================
# CONFIGURAÇÕES DA APLICAÇÃO — CLÍNICA VETERINÁRIA API
# Copie este arquivo para .env e preencha os valores
# =============================================================================

# ─── Aplicação ────────────────────────────────────────────────────────────────
APP_NAME="Clínica Veterinária API"
APP_VERSION="1.0.0"
DEBUG=false
ENVIRONMENT=development   # development | staging | production

# ─── Banco de Dados ──────────────────────────────────────────────────────────
# Formato: postgresql+asyncpg://<user>:<password>@<host>:<port>/<database>
DATABASE_URL=postgresql+asyncpg://clinica_user:clinica_pass@localhost:5432/clinica_veterinaria
DATABASE_URL_SYNC=postgresql+psycopg2://clinica_user:clinica_pass@localhost:5432/clinica_veterinaria

POSTGRES_USER=clinica_user
POSTGRES_PASSWORD=clinica_pass
POSTGRES_DB=clinica_veterinaria
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ─── JWT / Segurança ──────────────────────────────────────────────────────────
# Gere com: openssl rand -hex 32
SECRET_KEY=TROQUE_POR_UMA_CHAVE_SECRETA_SEGURA_DE_64_CHARS_MIN
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Usuário Admin Inicial ───────────────────────────────────────────────────
FIRST_SUPERUSER_EMAIL=admin@clinica.com
FIRST_SUPERUSER_PASSWORD=Admin@123456

# ─── CORS ────────────────────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
