# ─── Aplicação ────────────────────────────────────────────────────────────────
APP_NAME="Clínica Veterinária API"
APP_VERSION="1.0.0"
DEBUG=true
ENVIRONMENT=development

# ─── Banco de Dados ──────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://clinica_user:clinica_pass@db:5432/clinica_veterinaria
DATABASE_URL_SYNC=postgresql+psycopg2://clinica_user:clinica_pass@db:5432/clinica_veterinaria

POSTGRES_USER=clinica_user
POSTGRES_PASSWORD=clinica_pass
POSTGRES_DB=clinica_veterinaria
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ─── JWT / Segurança ──────────────────────────────────────────────────────────
SECRET_KEY=dev_secret_key_troque_em_producao_32chars_minimo_aqui
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Usuário Admin Inicial ───────────────────────────────────────────────────
FIRST_SUPERUSER_EMAIL=admin@clinica.com
FIRST_SUPERUSER_PASSWORD=Admin@123456

# ─── CORS ────────────────────────────────────────────────────────────────────
BACKEND_CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
